   "source": [
    "## Assert keyword"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "804105a8-54a4-4634-9e7a-49eef472ec22",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a number  3\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Number is not even\n"
     ]
    }
   ],
   "source": [
    "try:\n",
    "    num=int(input(\"Enter a number \"))\n",
    "    assert num%2==0 \n",
    "    print(\"Number is even\")\n",
    "except AssertionError:\n",
    "    print(\"Number is not even\")"
   ]
  },
  {
   "cell_type": "raw",
   "id": "16ef7616-f0ed-49dc-a1af-1481e32aabca",
   "metadata": {},
   "source": [
    "assert is used to check a condition.\n",
    "If the condition is True → nothing happens\n",
    "If the condition is False → it raises an error (AssertionError)"
   ]
  },
